# =============================================================================
# OpenVPN Configuration File Example
# =============================================================================
# Copy this file to myvpn.ovpn (or your vpn_config_name.ovpn) and fill in
# your actual VPN provider's configuration details.
#
# The file will be copied to /etc/openvpn/myvpn.conf on the target system.
# =============================================================================

# VPN Server Configuration
remote vpn-server.example.com 1194 udp

# Protocol
proto udp

# Device Type
dev tun

# Cipher and Authentication
cipher AES-256-CBC
auth SHA256

# TLS Configuration
tls-client
tls-version-min 1.2

# Certificate Authority (CA) - Replace with your provider's CA certificate
<ca>
-----BEGIN CERTIFICATE-----
# Paste your VPN provider's CA certificate here
-----END CERTIFICATE-----
</ca>

# Client Certificate (if required) - Replace with your client certificate
<cert>
-----BEGIN CERTIFICATE-----
# Paste your client certificate here (if required by your provider)
-----END CERTIFICATE-----
</cert>

# Client Key (if required) - Replace with your client private key
<key>
-----BEGIN PRIVATE KEY-----
# Paste your client private key here (if required by your provider)
-----END PRIVATE KEY-----
</key>

# TLS Authentication Key (if required)
<tls-auth>
-----BEGIN OpenVPN Static key V1-----
# Paste your TLS authentication key here (if required by your provider)
-----END OpenVPN Static key V1-----
</tls-auth>
key-direction 1

# Authentication
# If your VPN provider requires username/password, uncomment the next line
# and the role will automatically create /etc/openvpn/pass.txt
auth-user-pass

# Additional Options
resolv-retry infinite
nobind
persist-key
persist-tun
verb 3
mute 20

# Redirect all traffic through VPN (kill switch at VPN level)
redirect-gateway def1

# DNS Configuration (optional, some providers specify DNS servers)
# dhcp-option DNS 8.8.8.8
# dhcp-option DNS 8.8.4.4

