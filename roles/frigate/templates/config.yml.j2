mqtt:
  enabled: false

tls:
  enabled: false

# Hardware acceleration is configured per input because the camera streams
# use different codecs.
ffmpeg:
  hwaccel_args: []

record:
  enabled: true
  continuous:
    days: {{ frigate.retention_days }}

cameras:
  {{ frigate.camera_name }}:
    enabled: true
    ffmpeg:
      inputs:
        - path: "{{ frigate_doorbell_rtsp_url }}"
          roles:
            - record
        - path: "{{ frigate_doorbell_rtsp_url | regex_replace('/videoMain$', '/videoSub') }}"
          hwaccel_args: "-c:v h264_v4l2m2m"
          roles:
            - detect
    detect:
      enabled: false
      width: 640
      height: 360
      fps: 5
